{
  "name": "dopamine-fitness",
  "version": "1.0.0",
  "description": "Fitness workout tracking app on Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "dev:web": "npm --prefix ./web run dev",
    "dev:all": "concurrently -n \"workers,vite\" -c \"cyan,green\" \"wrangler dev --local --persist-to .wrangler/state\" \"npm --prefix ./web run dev\"",
    "web:install": "npm --prefix ./web install",
    "web:type-check": "npm --prefix ./web run type-check",
    "web:build": "npm --prefix ./web run build",
    "build:all": "npm run type-check && npm run web:type-check && npm run web:build",
    "smoke": "node ./scripts/smoke.mjs",
    "deploy": "wrangler deploy",
    "deploy:prod": "npm run build:all && wrangler deploy",
    "deploy:staging": "npm run build:all && wrangler deploy --env staging",
    "db:migrate:local": "wrangler d1 migrations apply dopamine-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply dopamine-db --remote",
    "db:migrate:staging": "wrangler d1 migrations apply dopamine-db-staging --remote --env staging",
    "db:seed:local": "wrangler d1 execute dopamine-db --local --file=./seeders/seed.sql",
    "db:seed:prod": "wrangler d1 execute dopamine-db --remote --file=./seeders/seed.sql",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240910.0",
    "@types/node": "^20.14.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "wrangler": "^3.65.0"
  }
}
