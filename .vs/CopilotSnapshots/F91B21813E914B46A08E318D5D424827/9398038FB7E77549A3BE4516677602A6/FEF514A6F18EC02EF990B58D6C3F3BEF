import { Hono } from "hono";
import type { Env, HonoVariables } from "../types/index.js";
import { authenticate } from "../middlewares/authenticate.js";
import { FavoritesRepository } from "../repositories/favoritesRepository.js";
import { z } from "zod";
import { validate } from "../validators/validate.js";

export const favoritesRoutes = new Hono<{ Bindings: Env; Variables: HonoVariables }>();

favoritesRoutes.use("*", authenticate());

const addFavoriteSchema = z.object({
  exercise_id: z.number().int().positive().optional(),
  custom_exercise_id: z.number().int().positive().optional(),
}).refine(
  (d) => d.exercise_id != null || d.custom_exercise_id != null,
  "Нужно указать exercise_id или custom_exercise_id"
);

// GET /favorites
favoritesRoutes.get("/", async (c) => {
  const userId = c.get("userId");
  const repo = new FavoritesRepository(c.env.DB);
  const favorites = await repo.list(userId);
  return c.json({ success: true, data: favorites });
});

// POST /favorites
favoritesRoutes.post("/", async (c) => {
  const userId = c.get("userId");
  const input = validate(addFavoriteSchema, await c.req.json());
  const repo = new FavoritesRepository(c.env.DB);
  const favorite = await repo.add(
    userId,
    input.exercise_id ?? null,
    input.custom_exercise_id ?? null
  );
  return c.json({ success: true, data: favorite }, 201);
});

// DELETE /favorites
favoritesRoutes.delete("/", async (c) => {
  const userId = c.get("userId");
  const input = validate(addFavoriteSchema, await c.req.json());
  const repo = new FavoritesRepository(c.env.DB);
  const removed = await repo.remove(
    userId,
    input.exercise_id ?? null,
    input.custom_exercise_id ?? null
  );
  if (!removed) throw new Error("Not found");
  return c.json({ success: true, message: "Удалено из избранного" });
});
