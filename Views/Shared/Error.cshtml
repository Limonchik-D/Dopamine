@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="hero-bg">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
</div>

<div class="hero" style="padding-top:6rem;">
    <div class="hero-card glass error-card">
        <div class="feat-icon">⚠️</div>
        <h1>Что-то пошло не так</h1>
        @if (Model?.ShowRequestId == true)
        {
            <p style="margin-top:1rem;font-size:0.8rem;color:var(--text-muted)">Request ID: <code>@Model.RequestId</code></p>
        }
        <div class="hero-actions" style="margin-top:2rem;">
            <a class="btn-primary" href="/">На главную</a>
        </div>
    </div>
</div>

