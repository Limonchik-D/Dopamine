# Dopamine Fitness — Environment Variables Reference

# ─── Required Secrets (wrangler secret put <NAME>) ──────────────────────────
# JWT_SECRET=<random 64-char string>
# EXERCISEDB_API_KEY=<your RapidAPI key for ExerciseDB>

# ─── wrangler.toml vars (already set, override if needed) ───────────────────
# ENVIRONMENT=production
# JWT_EXPIRES_IN=604800
# EXERCISE_CACHE_TTL=3600
# MAX_UPLOAD_SIZE_MB=5
# EXERCISEDB_BASE_URL=https://exercisedb.p.rapidapi.com
# WGER_BASE_URL=https://wger.de/api/v2
# APP_NAME=Dopamine Fitness
# APP_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com

# ─── Bindings (set in wrangler.toml, not .env) ───────────────────────────────
# DB          — D1 database binding
# KV          — KV namespace binding
# R2_BUCKET   — R2 bucket binding
