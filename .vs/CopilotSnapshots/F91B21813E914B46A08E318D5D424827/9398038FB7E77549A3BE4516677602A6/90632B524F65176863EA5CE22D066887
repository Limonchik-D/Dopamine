* { box-sizing: border-box; }

body {
  margin: 0;
  font-family: Inter, Segoe UI, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  font-size: var(--font-md);
}

a { color: var(--accent); text-decoration: none; }
a.active { font-weight: 600; }

.app-shell { min-height: 100vh; }
.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: var(--space-md);
  border-bottom: 1px solid var(--border);
  background: var(--surface);
}

.container {
  width: min(100%, 980px);
  margin: 0 auto;
  padding: var(--space-md);
}

.nav-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
}

.stack {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.row {
  display: flex;
  gap: var(--space-sm);
  align-items: center;
  flex-wrap: wrap;
}

input, select {
  width: 100%;
  max-width: 360px;
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text);
}

.btn {
  min-height: 44px;
  padding: 10px 14px;
  border: 1px solid var(--accent);
  background: var(--accent);
  color: #fff;
  border-radius: 10px;
  cursor: pointer;
}

.exercise-preview {
  max-width: 240px;
  width: 100%;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
}

@media (max-width: 640px) {
  .container { padding: var(--space-sm); }
  .btn { width: 100%; }
}
