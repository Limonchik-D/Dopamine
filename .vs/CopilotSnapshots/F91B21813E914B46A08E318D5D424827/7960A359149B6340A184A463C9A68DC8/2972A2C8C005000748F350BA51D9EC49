name = "dopamine-fitness"
main = "src/index.ts"
compatibility_date = "2024-09-10"
compatibility_flags = ["nodejs_compat"]

[assets]
directory = "./web/dist"
not_found_handling = "single-page-application"
run_worker_first = ["/api/*", "/health"]

# ─── D1 Database ────────────────────────────────────────────────────────────
[[d1_databases]]
binding = "DB"
database_name = "dopamine-db"
database_id = "REPLACE_WITH_YOUR_D1_ID"
migrations_dir = "migrations"

# ─── KV Namespaces ──────────────────────────────────────────────────────────
[[kv_namespaces]]
binding = "KV"
id = "REPLACE_WITH_YOUR_KV_ID"
preview_id = "REPLACE_WITH_YOUR_KV_PREVIEW_ID"

# ─── R2 Bucket ──────────────────────────────────────────────────────────────
[[r2_buckets]]
binding = "R2_BUCKET"
bucket_name = "dopamine-media"

# ─── Environment Variables ──────────────────────────────────────────────────
[vars]
ENVIRONMENT = "production"
JWT_EXPIRES_IN = "604800"
EXERCISE_CACHE_TTL = "3600"
MAX_UPLOAD_SIZE_MB = "5"
EXERCISEDB_BASE_URL = "https://exercisedb.p.rapidapi.com"
WGER_BASE_URL = "https://wger.de/api/v2"
APP_NAME = "Dopamine Fitness"
APP_ALLOWED_ORIGINS = "http://localhost:5173"

# ─── Secrets (set via: wrangler secret put SECRET_NAME) ─────────────────────
# JWT_SECRET
# EXERCISEDB_API_KEY
# BCRYPT_ROUNDS (optional, default 12)

# ─── Local Development ──────────────────────────────────────────────────────
[dev]
port = 8787
local_protocol = "http"

# ─── Environments ───────────────────────────────────────────────────────────
[env.staging]
name = "dopamine-fitness-staging"
vars = { ENVIRONMENT = "staging", APP_ALLOWED_ORIGINS = "https://staging.example.com" }

[env.staging.assets]
directory = "./web/dist"
not_found_handling = "single-page-application"
run_worker_first = ["/api/*", "/health"]

[[env.staging.d1_databases]]
binding = "DB"
database_name = "dopamine-db-staging"
database_id = "REPLACE_WITH_STAGING_D1_ID"
