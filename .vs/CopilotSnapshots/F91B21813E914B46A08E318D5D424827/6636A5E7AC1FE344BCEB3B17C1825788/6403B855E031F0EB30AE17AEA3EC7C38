import { createMiddleware } from "hono/factory";

export function requestId() {
  return createMiddleware(async (c, next) => {
    const id =
      c.req.header("cf-ray") ??
      crypto.randomUUID().replace(/-/g, "").slice(0, 16);
    c.set("requestId", id);
    c.header("X-Request-Id", id);
    await next();
  });
}
